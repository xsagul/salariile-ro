# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# claude code worktrees + state
.claude

# typescript
*.tsbuildinfo
next-env.d.ts

# audit surse (cărți locale, sub copyright) + log server local
/_books
.serverlog-*.txt

# Unealtă locală de validare D112 (nu se deployează)
/_d112-local

# Cheie service account Google Search Console (NU se commit-ează)
gsc-key.json
/.gsc/
